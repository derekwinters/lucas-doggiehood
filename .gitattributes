# Binary game assets are committed as regular git blobs (decided in #131 —
# Git LFS rules from #79 were never active in agent environments and all
# existing art is already raw blobs). "binary" marks them -text -diff -merge
# so git never EOL-normalizes or line-diffs them.

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.tif binary
*.tiff binary
*.exr binary
*.hdr binary
*.psd binary
*.ai binary

# 3D models
*.fbx binary
*.FBX binary
*.obj binary
*.blend binary
*.glb binary
*.gltf binary

# Audio
*.wav binary
*.mp3 binary
*.ogg binary
*.aif binary
*.aiff binary

# Video
*.mp4 binary
*.mov binary
*.webm binary

# Fonts
*.ttf binary
*.otf binary

# Archives / misc binaries
*.zip binary
*.7z binary
*.unitypackage binary
*.a binary
*.so binary
*.dll binary
*.dylib binary
